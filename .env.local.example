# Copy to .env.local and adjust. Next.js auto-loads .env.local (git-ignored).
# Public vars (exposed to the browser) MUST be prefixed with NEXT_PUBLIC_.
NEXT_PUBLIC_APP_NAME="Mayavé Packaging Audit"

# Server-only secrets (never prefixed) are available in Route Handlers / server
# components via process.env, e.g.:
# DATABASE_URL="postgres://…"
# API_BASE_URL="https://api.internal.mayave.example"
